---
import { Icon as AstroIcon } from "astro-icon/components"

type IconName =
  | "arrow-left"
  | "chevron-down"
  | "chevron-left"
  | "chevron-right"
  | "eye"
  | "github"
  | "globe"
  | "menu"
  | "monitor"
  | "moon"
  | "newspaper"
  | "rss"
  | "search"
  | "sun"
  | "x"
  | "simple-icons:mastodon"
  | "simple-icons:bluesky"

interface Props {
  name: IconName
  class?: string
  dataIcon?: "inline-start" | "inline-end"
}

const { name, class: className = "size-4", dataIcon } = Astro.props
const iconName = name.includes(":") ? name : `lucide:${name}`
---

<AstroIcon
  name={iconName}
  class={className}
  data-ui-icon={dataIcon}
  aria-hidden="true"
/>
