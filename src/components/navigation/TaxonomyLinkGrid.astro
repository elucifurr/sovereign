---
interface TaxonomyLink {
  href: string
  label: string
  count: number
  description?: string
}

interface TaxonomyDescription {
  label?: string
  description: string
}

interface Props {
  title: string
  items: TaxonomyLink[]
  descriptionItems?: TaxonomyDescription[]
  overviewTitle?: string
  class?: string
}

const {
  title,
  items,
  descriptionItems = items,
  overviewTitle,
  class: className = "",
} = Astro.props
const hiddenDescriptions = descriptionItems.filter((item) => item.description)
---

<section class={`mt-8 ${className}`}>
  <h2 class="mb-5 text-lg font-semibold text-foreground">{title}</h2>
  <div class="taxonomy-link-grid">
    {
      items.map((item) => (
        <a class="taxonomy-link" href={item.href}>
          <h3>{item.label}</h3>
          <span class="taxonomy-link__count">{item.count}</span>
        </a>
      ))
    }
  </div>
  {
    overviewTitle && hiddenDescriptions.length > 0 && (
      <section class="mt-8 grid gap-4" aria-labelledby="taxonomy-overview">
        <h2 id="taxonomy-overview" class="text-lg font-semibold text-foreground">
          {overviewTitle}
        </h2>
        <div class="grid gap-3 sm:grid-cols-2">
          {hiddenDescriptions.map((item) => (
            <article class="rounded-lg border border-border bg-background/70 p-4 dark:bg-white/[0.03]">
              <h3 class="text-sm font-semibold text-foreground">
                {item.label}
              </h3>
              <p class="mt-2 text-sm leading-6 text-muted-foreground">
                {item.description}
              </p>
            </article>
          ))}
        </div>
      </section>
    )
  }
  {
    hiddenDescriptions.length > 0 && !overviewTitle && (
      <div class="sr-only">
        {hiddenDescriptions.map((item) => (
          <p>
            {item.label} {item.description}
          </p>
        ))}
      </div>
    )
  }
</section>
